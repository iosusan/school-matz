# ── Meta-admin configuration ──────────────────────────────────
# Dominio raíz del servidor (todos los tenants viven bajo subdominios de este)
BASE_DOMAIN=miescuela.es

# ── Autenticación del meta-admin ──────────────────────────────
# Único administrador estático
META_ADMIN_USERNAME=admin

# Generar hash con:
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'tupassword', bcrypt.gensalt()).decode())"
META_ADMIN_PASSWORD_HASH=$2b$12$REEMPLAZA_CON_HASH_REAL

# Clave secreta para JWT del meta-admin
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
META_SECRET_KEY=REEMPLAZA_CON_CLAVE_ALEATORIA
