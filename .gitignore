# ── Python ────────────────────────────────────────────────────────────────────
.venv/
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/

# ── Entorno ───────────────────────────────────────────────────────────────────
.env
# .env.example sí se rastrea — es la plantilla sin secretos

# ── Base de datos (se genera en runtime) ──────────────────────────────────────
data/*.db
data/*.db-shm
data/*.db-wal

# ── Imágenes QR generadas ─────────────────────────────────────────────────────
static/qr/*.png
static/qr_usuarios/*.png

# ── Certificados SSL (NUNCA al repositorio) ───────────────────────────────────
certs/app.key
certs/app.crt
certs/rootCA.pem
certs/ca/
scripts/certs/
# Certs legacy (anteriores a v0.4)
certs/materiales.key
certs/materiales.crt

# ── Configuración generada en runtime ────────────────────────────────────────
config/domain
config/secret_key
docker/nginx.conf

# ── Editores ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.*.swp

# ── Sistema operativo ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log

# ── pip-audit ─────────────────────────────────────────────────────────────────
.pip-audit-cache/
