# docker-compose.yml — Generado automáticamente por el meta-admin.
# Tenant: {{ tenant_slug }}
# NO editar manualmente — los cambios se perderán en el próximo reset.
# ─────────────────────────────────────────────────────────────

services:

  app:
    image: school-matz:latest
    container_name: tenant-{{ tenant_slug }}
    restart: unless-stopped
    environment:
      DATABASE_URL: "sqlite:///./data/assets.db"
      QR_IMAGES_DIR: "./static/qr"
      TENANT_SLUG: "{{ tenant_slug }}"
      BASE_DOMAIN: "{{ base_domain }}"
      SECRET_KEY: "{{ secret_key }}"
    volumes:
      # Datos del tenant — bind mount para backups y acceso por tenant_stats
      - ./data:/app/data
      # Imágenes QR del material
      - ./static/qr:/app/static/qr
      # Imágenes QR de carnets de usuario
      - ./static/qr_usuarios:/app/static/qr_usuarios
    expose:
      - "8000"
    networks:
      - traefik_public
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.{{ tenant_slug }}.rule=Host(`{{ tenant_slug }}.{{ base_domain }}`)"
      - "traefik.http.routers.{{ tenant_slug }}.entrypoints=websecure"
      - "traefik.http.routers.{{ tenant_slug }}.tls.certresolver=letsencrypt"
      - "traefik.http.services.{{ tenant_slug }}.loadbalancer.server.port=8000"
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/api/v1/usuarios')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s

networks:
  traefik_public:
    external: true
