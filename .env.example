DATABASE_URL=sqlite:///./data/assets.db
QR_IMAGES_DIR=./static/qr

# ── Clave secreta para JWT ────────────────────────────────────
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
# Necesaria para despliegue Docker. En modo local se auto-genera en config/secret_key.
SECRET_KEY=

# ── Dominio del tenant ────────────────────────────────────────
# TENANT_SLUG:  identificador del subdominio (ej: "colegio-a")
# BASE_DOMAIN:  dominio raíz del servidor   (ej: "miescuela.es")
# QR_BASE_URL se deriva automáticamente: https://<TENANT_SLUG>.<BASE_DOMAIN>
# Se puede sobreescribir explícitamente si se necesita una URL distinta.
TENANT_SLUG=colegio-a
BASE_DOMAIN=miescuela.es
